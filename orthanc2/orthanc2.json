// orthanc2/orthanc2.json
{
  "Name": "ORTHANC2",
  "DicomPort": 4242,
  "HttpPort": 8043,
  "DicomAet": "ORTHANC2",
  "StorageDirectory": "/var/lib/orthanc/db",
  "AuthenticationEnabled": false,
  "AllowAllUsers": true,
  "RemoteAccessAllowed": true,
  "DicomAlwaysAllowStore": true,

  "Verbose": true,
  "LuaEnabled": true,
  "LuaScripts": [
    "/etc/orthanc/observer.lua"
  ],
  "ExecuteLuaEnabled": true
}
